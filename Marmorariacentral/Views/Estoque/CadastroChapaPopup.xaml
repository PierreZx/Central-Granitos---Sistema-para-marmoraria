<?xml version="1.0" encoding="utf-8" ?>
<mct:Popup
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:mct="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Class="Marmorariacentral.Views.Estoque.CadastroChapaPopup"
    Color="Transparent">

    <Grid BackgroundColor="#80000000" Padding="20">

        <Border
            BackgroundColor="White"
            Padding="25"
            WidthRequest="360"
            MaximumWidthRequest="500"
            HorizontalOptions="Center"
            VerticalOptions="Center">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="15">

                <Label
                    x:Name="LblTitulo"
                    Text="Nova Chapa"
                    FontSize="22"
                    FontAttributes="Bold"
                    TextColor="#8B1A1A"
                    HorizontalOptions="Center"
                    Margin="0,0,0,10"/>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Nome da Pedra" FontSize="12" TextColor="#666" Margin="5,0"/>
                    <Entry x:Name="EntryNome" 
                           Placeholder="Ex: Granito Preto Absoluto" 
                           PlaceholderColor="#999"
                           TextColor="Black" 
                           BackgroundColor="#F9F9F9"/>
                </VerticalStackLayout>

                <Grid ColumnDefinitions="*, *" ColumnSpacing="15">

                    <VerticalStackLayout Grid.Column="0" Spacing="5">
                        <Label Text="M² Total" FontSize="12" TextColor="#666" Margin="5,0"/>
                        <Entry x:Name="EntryMetro" 
                               Placeholder="0.00" 
                               Keyboard="Numeric" 
                               TextColor="Black"
                               PlaceholderColor="#999"
                               BackgroundColor="#F9F9F9"/>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                        <Label Text="Qtd Chapas" FontSize="12" TextColor="#666" Margin="5,0"/>
                        <Entry x:Name="EntryQtd" 
                               Placeholder="0" 
                               Keyboard="Numeric" 
                               TextColor="Black"
                               PlaceholderColor="#999"
                               BackgroundColor="#F9F9F9"/>
                    </VerticalStackLayout>

                </Grid>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Valor por M² (R$)" FontSize="12" TextColor="#666" Margin="5,0"/>
                    <Entry x:Name="EntryValor" 
                           Placeholder="0.00" 
                           Keyboard="Numeric" 
                           TextColor="Black"
                           PlaceholderColor="#999"
                           BackgroundColor="#F9F9F9"/>
                </VerticalStackLayout>

                <Button
                    Text="SALVAR NO ESTOQUE"
                    BackgroundColor="#8B1A1A"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="12"
                    Margin="0,15,0,0"
                    Clicked="OnSalvarClicked"/>

                <Button
                    Text="Cancelar"
                    BackgroundColor="Transparent"
                    TextColor="#777"
                    HeightRequest="45"
                    Clicked="OnCancelarClicked"/>

            </VerticalStackLayout>
        </Border>
    </Grid>
</mct:Popup>