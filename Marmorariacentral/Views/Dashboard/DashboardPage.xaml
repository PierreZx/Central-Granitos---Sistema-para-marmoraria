<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Marmorariacentral.ViewModels"
             xmlns:models="clr-namespace:Marmorariacentral.Models"
             x:Class="Marmorariacentral.Views.Dashboard.DashboardPage"
             x:DataType="viewmodels:DashboardViewModel"
             Title="Dashboard"
             BackgroundColor="#F2F2F7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,10">
                <Label Grid.Column="0" 
                       Text="Visão Geral" 
                       FontSize="28" 
                       FontAttributes="Bold" 
                       TextColor="#333333" />

                <Button Grid.Column="1"
                        Text="🔔"
                        BackgroundColor="Transparent"
                        TextColor="#8B1A1A"
                        FontSize="20"
                        WidthRequest="45"
                        HeightRequest="45"
                        Padding="0"
                        Command="{Binding TestarNotificacaoCommand}"
                        VerticalOptions="Center"
                        Margin="0,0,10,0">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.05" Offset="0,2" Radius="2" />
                    </Button.Shadow>
                </Button>

                <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                    <Label Text="Sinc" FontSize="11" TextColor="#777777" VerticalOptions="Center"/>
                    <Border BackgroundColor="{Binding WifiStatusColor}"
                            WidthRequest="14"
                            HeightRequest="14"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 50"
                            VerticalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="Black" Opacity="0.1" Radius="2" />
                        </Border.Shadow>
                    </Border>
                </HorizontalStackLayout>
            </Grid>

            <Border StrokeShape="RoundRectangle 15" 
                    StrokeThickness="0" 
                    BackgroundColor="#8B1A1A" 
                    Padding="25">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,10" Opacity="0.1" Radius="15"/>
                </Border.Shadow>
                
                <VerticalStackLayout Spacing="5">
                    <Label Text="Saldo Total Disponível" 
                           TextColor="#FFCCCC" 
                           FontSize="14" />
                    <Label Text="{Binding ValorCaixa}" 
                           TextColor="White" 
                           FontSize="36" 
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Próximos Vencimentos" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="#333333"
                   Margin="0,10,0,0" />

            <CollectionView ItemsSource="{Binding AlertasProximos}"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FinanceiroRegistro">
                        <Border Margin="0,0,0,10" 
                                Padding="15" 
                                StrokeShape="RoundRectangle 12" 
                                BackgroundColor="White"
                                StrokeThickness="0">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Opacity="0.05" Radius="5"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="*, Auto">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding DescricaoDisplay}" 
                                           FontAttributes="Bold" 
                                           TextColor="#333333" 
                                           FontSize="15"/>
                                    <Label Text="{Binding DataVencimento, StringFormat='Vence em {0:dd/MM/yyyy}'}" 
                                           FontSize="12" 
                                           TextColor="#777777"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" 
                                       Text="{Binding Valor, StringFormat='{0:C}'}" 
                                       TextColor="#8B1A1A" 
                                       FontAttributes="Bold" 
                                       VerticalOptions="Center"
                                       FontSize="15"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                
                <CollectionView.EmptyView>
                    <Border StrokeShape="RoundRectangle 15" 
                            StrokeThickness="0" 
                            BackgroundColor="White" 
                            HeightRequest="150" 
                            Padding="20">
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="10">
                            <Label Text="✅" FontSize="40" HorizontalOptions="Center" />
                            <Label Text="Tudo em dia!" 
                                   HorizontalOptions="Center" 
                                   TextColor="#666666" 
                                   FontSize="16"
                                   FontAttributes="Bold"/>
                            <Label Text="Não há contas próximas do vencimento." 
                                   HorizontalOptions="Center" 
                                   TextColor="#999999" 
                                   FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>